# MNEMOS v5.3.2 Configuration
# Copy to .env and customize for your deployment.
# Only env names actually read by mnemos/core/config.py are listed
# here; orphan names from earlier release lines were dropped in
# slice #195. If you need a feature flag that isn't shown, check
# mnemos/core/config.py first to confirm the canonical alias.

# ── Server Configuration ──────────────────────────────────────────────────────
MNEMOS_PORT=5002
MNEMOS_BIND=127.0.0.1

# ── Database Configuration ────────────────────────────────────────────────────
# PostgreSQL connection for memory storage, audit logs, sessions, and DAG versioning.
# _DatabaseSettings uses env_prefix="PG_" so unprefixed PG_* are auto-bound.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mnemos
PG_USER=mnemos
PG_PASSWORD=your_secure_password_here
PG_POOL_MIN=5
PG_POOL_MAX=20
MNEMOS_POOL_ACQUIRE_TIMEOUT=10.0

# ── GPU Provider Configuration ────────────────────────────────────────────────
# Optional: local GPU for APOLLO LLM fallback and judge scoring.
# Supported: vLLM, Ollama, or any OpenAI-compatible inference server.
# MNEMOS works without GPU but falls back to CPU compression (slower).
GPU_PROVIDER_HOST=http://localhost
GPU_PROVIDER_PORT=8000
GPU_PROVIDER_TIMEOUT=30.0

# ── Embedding Inference ───────────────────────────────────────────────────────
# Backend-agnostic embedding endpoint (llama.cpp llama-server, Ollama, vLLM,
# NVIDIA NIM, or any OpenAI-compat /v1/embeddings server). Wire shape is
# auto-detected.
INFERENCE_EMBED_HOST=http://localhost:11434
INFERENCE_EMBED_MODEL=nomic-embed-text
INFERENCE_EMBED_TIMEOUT=10

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# For GRAEAE multi-provider consensus engine.
# Recommended: Together AI and Groq (free tier available).
TOGETHER_API_KEY=your_together_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Authentication ────────────────────────────────────────────────────────────
# Bearer token material for team/enterprise installs.
# Personal profile leaves auth disabled unless config.toml enables [auth].enabled = true.
# Generate with: openssl rand -hex 32
MNEMOS_API_KEY=your_secure_api_key_here

# ── Redis (Optional) ──────────────────────────────────────────────────────────
# Single URL — _ServerSettings.redis_url accepts MNEMOS_REDIS_URL or REDIS_URL.
# Used for compression-cache + (optionally) rate-limit storage when
# RATE_LIMIT_STORAGE_URI=redis://...
# REDIS_URL=redis://localhost:6379/0

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
# RATE_LIMIT_STORAGE_URI=memory://     # or redis://localhost:6379/1
# RATE_LIMIT_PER_MINUTE=60

# ── CORS Configuration ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://127.0.0.1:5002

# ── Request Size Limit ────────────────────────────────────────────────────────
MAX_BODY_BYTES=5242880  # 5 MB

# ── Logging ───────────────────────────────────────────────────────────────────
MNEMOS_LOG_LEVEL=INFO

# ── Compression Feature Flags ─────────────────────────────────────────────────
MNEMOS_CONTEST_ENABLED=true
MNEMOS_APOLLO_ENABLED=true
MNEMOS_APOLLO_LLM_FALLBACK_ENABLED=true
MNEMOS_JUDGE_ENABLED=false
# MNEMOS_JUDGE_MODE=llm     # one of: llm | cross | ensemble | heuristic

# ── GRAEAE Provider Configuration ─────────────────────────────────────────────
# Multi-provider consensus engine for reasoning tasks.
GRAEAE_PROVIDERS=together,groq,openai,anthropic
